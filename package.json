{
  "name": "mekeshbuilds",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:prod": "npm run build",
    "preview": "vite preview",
    "deploy": "firebase deploy --project mekeshbuild",
    "deploy:hosting": "firebase deploy --only hosting --project mekeshbuild",
    "deploy:rules": "firebase deploy --only firestore:rules,database:rules --project mekeshbuild",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:ci": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@hookform/resolvers": "^5.0.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-query": "^5.75.5",
    "chart.js": "^4.4.8",
    "express": "^5.2.1",
    "firebase": "^12.11.0",
    "framer-motion": "^12.6.3",
    "fuse.js": "^7.0.0",
    "html2canvas": "^1.4.1",
    "immer": "^11.1.4",
    "jspdf": "^4.2.1",
    "react": "^19.1.0",
    "react-chartjs-2": "^5.3.0",
    "react-countup": "^6.5.3",
    "react-dom": "^19.1.0",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.55.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.4.0",
    "recharts": "^3.8.1",
    "roughjs": "^4.6.6",
    "sweetalert2": "^11.15.10",
    "three": "^0.183.2",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/three": "^0.183.1",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.1.3",
    "@vitest/ui": "^3.1.3",
    "eslint": "^9.25.1",
    "eslint-import-resolver-typescript": "^3.10.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "firebase-tools": "^15.12.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.5.1",
    "msw": "^2.8.4",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-sitemap": "^0.8.2",
    "vitest": "^3.1.3",
    "workbox-window": "^7.4.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "src/**/*.{css,md,json}": [
      "prettier --write"
    ]
  }
}
