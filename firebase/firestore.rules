rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerClaim() {
      return isSignedIn() && (
        request.auth.token.owner == true ||
        request.auth.token.admin == true ||
        request.auth.token.role in ['owner', 'admin', 'super_admin', 'superadmin', 'root']
      );
    }

    function isOwnerProfile() {
      return isSignedIn() && (
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['owner', 'admin', 'super_admin', 'superadmin', 'root']
        ) || (
          exists(/databases/$(database)/documents/user/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/user/$(request.auth.uid)).data.role in ['owner', 'admin', 'super_admin', 'superadmin', 'root']
        ) || (
          exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role in ['owner', 'admin', 'super_admin', 'superadmin', 'root']
        )
      );
    }

    function isConfiguredOwnerEmail() {
      return isSignedIn() && request.auth.token.email == 'mekesh.engineer@gmail.com';
    }

    function isOwner() {
      return isOwnerClaim() || isOwnerProfile() || isConfiguredOwnerEmail();
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /profiles/{uid} {
      allow read: if isSelf(uid) || isOwner();

      // Self-registration can only create a user role profile (no privilege escalation).
      allow create: if isSelf(uid)
        && request.resource.data.role == 'user'
        && request.resource.data.email == request.auth.token.email;

      // Self-update cannot alter role/email. Owner can update anything.
      allow update: if isOwner() || (
        isSelf(uid)
        && request.resource.data.role == resource.data.role
        && request.resource.data.email == resource.data.email
      );

      allow delete: if isOwner();
    }

    match /user/{uid} {
      allow read: if isSelf(uid) || isOwner();

      // Self-registration can create user docs without privilege escalation.
      allow create: if isSelf(uid)
        && request.resource.data.email == request.auth.token.email
        && (
          request.resource.data.role == 'user' ||
          (isConfiguredOwnerEmail() && request.resource.data.role in ['owner', 'admin'])
        );

      // Self-update cannot change role/email. Owner may manage all user docs.
      allow update: if isOwner() || (
        isSelf(uid)
        && request.resource.data.role == resource.data.role
        && request.resource.data.email == resource.data.email
      );

      allow delete: if isOwner();
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || isOwner();

      // Self-registration can create user docs without privilege escalation.
      allow create: if isSelf(uid)
        && request.resource.data.email == request.auth.token.email
        && (
          request.resource.data.role == 'user' ||
          (isConfiguredOwnerEmail() && request.resource.data.role in ['owner', 'admin'])
        );

      // Self-update cannot change role/email. Owner may manage all user docs.
      allow update: if isOwner() || (
        isSelf(uid)
        && request.resource.data.role == resource.data.role
        && request.resource.data.email == resource.data.email
      );

      allow delete: if isOwner();
    }

    // Owner-managed data domains.
    match /projects/{docId} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /blogPosts/{docId} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /settings/{docId} {
      allow read, write: if isOwner();
    }

    match /analytics/{docId} {
      allow read, write: if isOwner();
    }

    match /contactSubmissions/{docId} {
      allow create: if true;
      allow read, update, delete: if isOwner();
    }

    // Default deny for all other collections.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
