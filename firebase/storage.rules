rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerClaim() {
      return isSignedIn() && (
        request.auth.token.owner == true ||
        request.auth.token.admin == true ||
        request.auth.token.role in ['owner', 'admin', 'super_admin', 'superadmin', 'root']
      );
    }

    function isConfiguredOwnerEmail() {
      return isSignedIn() && request.auth.token.email == 'mekesh.engineer@gmail.com';
    }

    function isOwner() {
      return isOwnerClaim() || isConfiguredOwnerEmail();
    }

    // Public read for portfolio assets; owner-only write.
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner();
    }

    // Restrict admin/private files to owner only.
    match /admin/{allPaths=**} {
      allow read, write: if isOwner();
    }

    // User uploads must be scoped to their uid, owner can access all.
    match /users/{uid}/{allPaths=**} {
      allow read: if isOwner() || (isSignedIn() && request.auth.uid == uid);
      allow write: if isOwner() || (isSignedIn() && request.auth.uid == uid);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
