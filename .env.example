# ── Firebase (Required) ──────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_DATABASE_URL=

# ── App URL (Required) ───────────────────────────────────────────
VITE_APP_URL=http://localhost:5000
# Optional owner fallback for role checks (use when metadata role is unavailable)
VITE_OWNER_EMAIL=your-email@example.com

# ── Google Maps (Optional — Contact page) ────────────────────────
VITE_GOOGLE_MAPS_API_KEY=

# ── Seed Script Only (Never prefix with VITE_) ───────────────────
OWNER_EMAIL=your-email@example.com
OWNER_PASSWORD=YourStrongPassword123!
OWNER_FULL_NAME=Your Name
OWNER_USERNAME=your-username
